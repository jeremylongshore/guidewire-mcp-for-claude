{
  "name": "@intentsolutions/policycenter-mcp",
  "version": "0.1.0",
  "description": "PolicyCenter MCP server — 5 read-only carrier-vocabulary tools for line underwriters (E2 of the Guidewire MCP for Claude blueprint).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "policycenter-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "dev:stdio": "tsx src/cli.ts --transport stdio",
    "dev:http": "tsx src/cli.ts --transport http --port 3030",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@intentsolutions/guidewire-auth": "workspace:*",
    "@intentsolutions/guidewire-client": "workspace:*",
    "@intentsolutions/guidewire-harness": "workspace:^",
    "@intentsolutions/guidewire-mcp-runtime": "workspace:*",
    "@intentsolutions/guidewire-observability": "workspace:*",
    "@intentsolutions/guidewire-schemas": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@opentelemetry/api": "^1.9.0",
    "js-yaml": "^4.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
