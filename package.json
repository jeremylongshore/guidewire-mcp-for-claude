    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.2",
      "ip-address": ">=10.1.1"
    }
  }
