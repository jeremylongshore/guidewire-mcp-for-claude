{
  "name": "guidewire-mcp-for-claude",
  "version": "0.1.1",
  "private": true,
  "description": "Carrier-native MCP servers + governance harness for Guidewire estates, designed Claude/Anthropic-first.",
  "license": "Apache-2.0",
  "author": "Jeremy Longshore <jeremy@intentsolutions.io>",
  "homepage": "https://github.com/jeremylongshore/guidewire-mcp-for-claude",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeremylongshore/guidewire-mcp-for-claude.git"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --no-bail test",
