#!/bin/sh
# ============================================================================
# STUB — regenerate with: gradle wrapper --gradle-version 8.7
# ============================================================================
# This file is a placeholder. The real Gradle wrapper script is generated by
# running `gradle wrapper` from within tests/contract/ using a locally
# installed Gradle 8.x. The generated script downloads and caches the exact
# Gradle distribution pinned in gradle/wrapper/gradle-wrapper.properties.
#
# Why this is a stub:
#   The CI environment running this scaffold generation does not have a local
#   `gradle` binary available to call `gradle wrapper`. The actual gradlew
#   binary is ~10 KB of shell that bootstraps the Gradle distribution download.
#   Writing a hand-crafted approximation would be fragile and misleading.
#
# How to generate the real file:
#   1. Install any Gradle 8.x release:
#        sdk install gradle 8.7       # via sdkman
#        brew install gradle          # macOS
#        apt install gradle           # Debian/Ubuntu (may be older — prefer sdkman)
#   2. cd tests/contract
#   3. gradle wrapper --gradle-version 8.7
#      This writes the real gradlew, gradlew.bat, gradle/wrapper/gradle-wrapper.jar,
#      and updates gradle/wrapper/gradle-wrapper.properties.
#   4. chmod +x gradlew
#   5. git add gradlew gradlew.bat gradle/wrapper/
#
# Until then, run Gradle directly:
#   gradle test                       # if gradle is on PATH
#   gradle karateRecord
# ============================================================================
echo "ERROR: gradlew is a stub. Run 'gradle wrapper --gradle-version 8.7' inside tests/contract/ to generate the real wrapper." >&2
exit 1
