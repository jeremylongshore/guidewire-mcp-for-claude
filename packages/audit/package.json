{
  "name": "@intentsolutions/guidewire-audit",
  "version": "0.1.1",
  "description": "Postgres-backed hash-chain audit store for the Guidewire harness; verifyChain detects tampering.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "migrations", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@intentsolutions/guidewire-observability": "workspace:*",
    "@intentsolutions/guidewire-schemas": "workspace:*",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/pg": "^8.0.0",
    "testcontainers": "^11.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  }
}
